{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "../dist-types/metering-backend",
    "rootDir": "."
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "dist-dynamic", "dist-types", "**/__tests__/**", "**/*.test.ts"]
}
